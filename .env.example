# ─────────────────────────────────────────────────
# Realtor Site Starter — environment variables
# Copy to .env.local and fill in values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────

# OpenAI — required for image generation (scripts/prompts.json)
# Get API key at: https://platform.openai.com/api-keys
# Org must be verified for gpt-image-2 access — see PLAYBOOK.md
OPENAI_API_KEY=

# Production site URL — used for canonical metadata, sitemap, robots.txt
# Set to actual domain before launch (e.g. https://brandname.ca)
NEXT_PUBLIC_SITE_URL=https://example.ca

# Webhook for Google Sheets lead capture (optional)
# If unset, form submissions are logged to console instead.
# Set up via Apps Script web app or Zapier/Make webhook.
CONTACT_SHEETS_WEBHOOK_URL=

# Separate webhook for estimator submissions (falls back to CONTACT_SHEETS_WEBHOOK_URL if unset)
ESTIMATE_SHEETS_WEBHOOK_URL=

# Brevo transactional email (optional — for realtor lead notifications)
# Wire up in app/api/contact/route.ts and app/api/estimate/route.ts
BREVO_API_KEY=

# Vercel deploy token (only needed for CLI deploys — not for GitHub auto-deploy)
VERCEL_API_TOKEN=
VERCEL_SCOPE=
